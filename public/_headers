# Long-cache hashed assets (Vite produces hashed filenames so cache-bust is automatic)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache static images and fonts (filenames don't change)
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache root-level static assets (logos, og images)
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML must revalidate so users always see latest deploy
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# robots, sitemap — short cache
/robots.txt
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600
