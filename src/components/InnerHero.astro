---
// src/components/InnerHero.astro
//
// Two layouts: with bgImage (full-bleed image background, dark overlay,
// centered title, taller min-height) and without (solid bg-dark-elevated,
// title in container, shorter top padding).
//
// When bgImage is provided, optionally accepts bgImageMobile (the smaller
// width variant for mobile viewports). If both are provided, emits a
// <picture> element so the browser picks the smaller asset on phones.
// Mobile breakpoint matches Tailwind's `md:` boundary (768px) — viewports
// below this get the mobile asset; viewports at or above get the desktop.

interface Props {
  title: string;
  bgImage?: string;
  bgImageAlt?: string;
  bgImageMobile?: string;
  // 'cover' (default): image fills the hero, may crop. Best for hi-res
  //   sources (1400px+) where edge cropping is acceptable.
  // 'contain': image fits within the hero, no crop, may letterbox.
  //   Best for low-res sources where stretching would visibly blur.
  bgImageFit?: 'cover' | 'contain';
}

const { title, bgImage, bgImageAlt = '', bgImageMobile, bgImageFit = 'cover' } = Astro.props;
const objectFitClass = bgImageFit === 'contain' ? 'object-contain' : 'object-cover';
---

{bgImage ? (
  <div class="relative flex items-center pt-32 pb-20 md:pt-36 md:pb-24 lg:pt-40 lg:pb-28 min-h-[420px] md:min-h-[480px] lg:min-h-[535px] border-b border-border-subtle overflow-hidden bg-dark-elevated">
    <picture>
      {bgImageMobile && (
        <source media="(max-width: 767px)" srcset={bgImageMobile} type="image/webp" />
      )}
      <img
        src={bgImage}
        alt={bgImageAlt}
        aria-hidden={bgImageAlt ? undefined : 'true'}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class={`absolute inset-0 w-full h-full ${objectFitClass}`}
      />
    </picture>
    <div class="absolute inset-0 bg-black/60" aria-hidden="true" />
    <div class="relative max-w-[1200px] mx-auto px-6 lg:px-[clamp(2rem,5vw,4rem)] text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">{title}</h1>
    </div>
  </div>
) : (
  <div class="pt-36 pb-12 md:pt-40 md:pb-16 bg-dark-elevated border-b border-border-subtle">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-[clamp(2rem,5vw,4rem)]">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">{title}</h1>
    </div>
  </div>
)}
