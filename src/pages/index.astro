---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Test" description="Test description for smoke check">
  <h1>Layout smoke test</h1>
  <p>Reveal test:</p>
  <div data-reveal>This element should fade in</div>
  <div data-reveal data-reveal-delay="0.2">This one with delay</div>
  <button id="test-modal-trigger" type="button">Open service modal (test)</button>
  <script is:inline>
    document.getElementById('test-modal-trigger')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-service-modal'));
    });
  </script>
</Layout>
