---
// src/pages/index.astro
// Homepage — replaces the placeholder used during foundation smoke
// checks. Byte-identical content port of pre-migration src/App.jsx
// HomePage (line 1030) which composes:
//   <Hero /> <BusinessDescription /> <WhyChooseUs /> <Services />
//   <CustomerSay /> <FAQ /> <FindUs /> <FinalCTA />
//
// Pre-migration HomePage does NOT call PageHead — the homepage's
// title/description/canonical/OG were baked into static index.html
// <head>. Post-migration, Layout.astro owns those (per-route props)
// and the static index.html template <head> is no longer the source
// of truth for the homepage.
//
// Two per-page JSON-LD schemas emitted via <Fragment slot="head">:
//   1. LocalBusiness — 33 @types, JSON.stringify byte-length 2016
//      (LocalBusiness, PostalAddress, GeoCoordinates, City,
//      OfferCatalog, 14×Offer, 14×Service)
//   2. FAQPage — 17 @types, JSON.stringify byte-length 2270
//      (FAQPage, 8×Question, 8×Answer)
// Total: 50 @types. Note migration-baseline.md §5b says "38" but
// schemas have grown since baseline was authored; migration
// preserves the actual current 50 byte-identical.
//
// FAQPage schema items 3 and 5 use ASCII hyphen with spaces (' - ')
// where the visible body FAQ (FAQS data) uses em-dash (U+2014).
// This pre-existing parity gap is preserved verbatim. Logged as
// FAQ-2 (P3) in post-migration-improvements.md.
//
// Hero image preload <link> is homepage-only — emitted via head
// slot (NOT in Layout, which serves all 13 pages with different
// hero images / no hero image). Astro accepts lowercase
// imagesrcset / imagesizes attribute names verbatim.
//
// Hero uses CSS @keyframes animations (5 classes from global.css:
// hero-image-animate, hero-title-animate, hero-badge-animate,
// hero-content-animate, hero-buttons-animate). NO data-reveal
// observers on Hero — animations fire on load (above-the-fold).
//
// 15 data-reveal divs total across 7 below-the-fold sections:
//   BusinessDescription:  2 (text 0, img 0.15)
//   WhyChooseUs:          1 + 4 cards (header 0; cards 0/0.1/0.2/0.3)
//   Services:             2 (header 0, intro 0.1)
//   CustomerSay:          1 (header 0)
//   FAQ:                  1 (header 0)
//   FindUs:               3 (heading 0, map 0.1, caption 0.2)
//   FinalCTA:             1 (anim 0)
//
// Modal triggers (Hero "New Service Request" + FinalCTA "New
// Service Request") use Layout's CustomEvent('open-service-modal')
// bridge via id-attached buttons + a single inline <script>.
//
// 4 internal links (Services rows) → 4 child Hubbard pages.
// 4 phone-CTA buttons in body (Hero, BusinessDescription, Services
// bottom, FinalCTA). Plus 3 inline phone links inside FAQ answers
// (rendered by FaqAccordion via linkifyPhone).
//
// 6 page-content <img>: 1 Hero LCP (eager + fetchpriority=high),
// 1 BusinessDescription tommy-sydney, 4 Services rows. The
// BusinessDescription image is missing width/height attributes in
// pre-migration — preserved as-is per delivery-layer-only scope.
//
// <ReviewWidget hideHeader client:idle /> is the third consumer of
// the ReviewWidget island and the FIRST one with the hideHeader
// boolean prop (others: /reviews, /garbage-collection-service-hubbard,
// /waste-management-service-hubbard — all without hideHeader).
import Layout from '../layouts/Layout.astro';
import ReviewWidget from '../components/ReviewWidget.tsx';
import FaqAccordion from '../components/FaqAccordion.tsx';
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import { FAQS } from '../data/faqs';
import { PHONE, PHONE_LINK } from '../data/business';
---

<Layout
  title="Trash Pickup & Waste Management in Hubbard, TX | Rankin Waste"
  description="Reliable trash pickup and waste management service in Hubbard, TX and surrounding rural communities. Family-owned, 250+ five-star reviews, no contracts. Call (254) 205-6125."
>
  <Fragment slot="head">
    {/* Hero image preload — homepage-only LCP optimization. Astro
        accepts lowercase imagesrcset/imagesizes verbatim per HTML spec. */}
    <link
      rel="preload"
      as="image"
      type="image/webp"
      href="/truck-side.webp"
      imagesrcset="/truck-side-mobile.webp 900w, /truck-side.webp 1600w"
      imagesizes="100vw"
    />

    {/* LocalBusiness Schema (33 @types, JSON.stringify = 2016 bytes) */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Rankin Waste Management",
      "description": "Professional waste management services serving Hubbard and surrounding areas for 6 years. Offering garbage removal, residential trash pickup, dumpster rental, junk removal, and construction debris removal with no contracts or hidden fees.",
      "url": "https://rankinwaste.com/",
      "telephone": "(254) 205-6125",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "175 PR335",
        "addressLocality": "Hubbard",
        "addressRegion": "TX",
        "postalCode": "76648"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 31.8468,
        "longitude": -96.8011
      },
      "openingHours": ["Mo-Fr 08:00-18:00"],
      "areaServed": {
        "@type": "City",
        "name": "Hubbard and surrounding areas"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Garbage Removal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Weekly Residential Trash Pickup" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Curbside Trash Collection" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rural Trash Service" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Junk Removal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Appliance removal & disposal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Furniture removal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "House & garage cleanouts" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Yard debris removal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Construction debris removal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Electronic waste removal & disposal" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Residential Dumpster Rental" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Dumpster Rental" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roll-off Dumpster Service" } }
        ]
      },
      "priceRange": "$$"
    })} />

    {/* FAQPage Schema (17 @types, JSON.stringify = 2270 bytes).
        Items 3 and 5 use ASCII hyphen with spaces (' - ') verbatim
        from pre-migration index.html — NOT em-dash. Visible body FAQ
        (via FAQS) uses em-dash for the same items. Parity gap
        preserved per delivery-layer-only scope (FAQ-2 P3). */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What areas do you serve around Hubbard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We serve Hubbard and surrounding communities across Hill, Navarro, Limestone, and McLennan Counties, including Axtell, Dawson, Malone, Mertens, Whitney, and other rural areas. If you're not sure we serve your area, call us directly at (254) 205-6125."
          }
        },
        {
          "@type": "Question",
          "name": "Do you require long-term contracts or have cancellation fees?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No contracts required and no cancellation fees ever. You're never locked in and can adjust or cancel service anytime without penalties."
          }
        },
        {
          "@type": "Question",
          "name": "What can I put out for pickup - do I need to sort anything?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No sorting required. Put out bags or cans with your household waste and we handle everything. Much simpler than most municipal programs."
          }
        },
        {
          "@type": "Question",
          "name": "How much does weekly trash pickup cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer flat-rate pricing with no fuel surcharges, environmental fees, or surprise charges. Call (254) 205-6125 for current rates in your area."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if you miss my pickup day?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We personally guarantee pickup reliability, but if any issue occurs, you reach the owners directly who resolve problems immediately - no ticket queues or call center delays."
          }
        },
        {
          "@type": "Question",
          "name": "Do you offer bulk pickup for furniture and appliances?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we provide bulk pickup services for large items like furniture and appliances in addition to regular weekly waste pickup."
          }
        },
        {
          "@type": "Question",
          "name": "How do I schedule or cancel service?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Call us directly at (254) 205-6125 to speak with Tommy or Sydney Rankin, or book online at rankinwaste.com."
          }
        },
        {
          "@type": "Question",
          "name": "Are there extra fees for fuel or environmental charges?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No hidden fees ever. Our flat-rate pricing means you know exactly what you pay each month without surprise charges or annual increases."
          }
        }
      ]
    })} />
  </Fragment>

  {/* ═══════════════════════ HERO ═══════════════════════ */}
  <header id="top" class="min-h-[70vh] sm:min-h-[65vh] md:min-h-[62vh] w-full flex flex-col justify-center items-center text-center px-6 relative overflow-hidden pb-8">
    {/* Background image — LCP, eager+high priority */}
    <div class="absolute inset-0">
      <img
        src="/truck-side.webp"
        srcset="/truck-side-mobile.webp 900w, /truck-side.webp 1600w"
        sizes="100vw"
        alt=""
        width="1600"
        height="1067"
        class="w-full h-full object-cover object-center hero-image-animate"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(8,8,8,0.55) 0%, rgba(8,8,8,0.45) 40%, rgba(8,8,8,0.6) 70%, rgba(8,8,8,0.85) 100%)"></div>
    </div>

    <div class="relative z-10 max-w-[900px] mx-auto pt-32 md:pt-24">
      <h1 class="text-[clamp(2rem,6vw,4rem)] font-bold leading-[1.1] tracking-tight drop-shadow-lg mb-4 hero-title-animate">
        Reliable Trash Pickup & Waste Management Service
      </h1>
      <p class="text-orange-500 text-lg sm:text-xl font-semibold mb-4 hero-badge-animate">
        Locally Family-Owned &amp; Operated
      </p>

      {/* Social proof */}
      <div class="flex items-center justify-center gap-1.5 mb-5 hero-content-animate">
        <span class="flex gap-0.5 text-star">
          <span class="text-lg">★</span><span class="text-lg">★</span><span class="text-lg">★</span><span class="text-lg">★</span><span class="text-lg">★</span>
        </span>
        <span class="text-white/90 text-sm sm:text-base font-medium ml-1">250+ Five-Star Google Reviews</span>
      </div>

      <p class="text-white/80 text-base sm:text-lg max-w-[600px] mx-auto mb-7 hero-content-animate">
        Proudly serving Hubbard, Axtell, Dawson, Malone, Mertens, Purdon, TX, and surrounding rural communities with reliable, affordable trash service.
      </p>

      <div class="flex flex-wrap justify-center gap-4 mb-8 hero-buttons-animate">
        <a href={PHONE_LINK} class="bg-orange-500 text-white px-7 py-3.5 rounded-full font-bold text-base hover:bg-orange-600 transition-colors duration-300 min-h-[44px] flex items-center gap-2">
          <PhoneIcon class="w-5 h-5" />
          Call Now {PHONE}
        </a>
        <button id="hero-modal-trigger" type="button" class="bg-white/10 backdrop-blur-sm border border-white/30 text-white px-7 py-3.5 rounded-full font-semibold text-base hover:bg-white/20 transition-all duration-300 min-h-[44px]">
          New Service Request
        </button>
      </div>

      {/* Trust badges — 6 inline spans (used 6× only on this page) */}
      <div class="flex flex-wrap justify-center gap-3 hero-buttons-animate">
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">No Contracts</span>
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">Flat-Rate Pricing</span>
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">Family Owned</span>
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">Weekly Pickup</span>
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">700+ Customers Served</span>
        <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium">Licensed &amp; Insured</span>
      </div>
    </div>
  </header>

  {/* ═══════════════════════ BUSINESS DESCRIPTION ═══════════════════════ */}
  <section class="bg-dark-elevated px-6 lg:px-[clamp(2rem,5vw,4rem)] py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div data-reveal>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-medium tracking-tight leading-tight mb-6">Built for Rural Texas Communities That Deserve Better</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4">
            Rankin Waste Management is a locally family-owned and operated small business proudly serving Hubbard, Axtell, Dawson, Malone, Mertens, Purdon, TX, and surrounding rural communities. We specialize in reliable, affordable trash service with a personal touch.
          </p>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4">
            As a part of the community, we understand the unique needs of rural areas and are committed to providing dependable weekly pickup and trash trailer rentals at competitive prices.
          </p>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-8">
            When you choose Rankin Waste Management, you're not just getting great service - you're supporting your neighbors. Let us take care of your waste so you can focus on what matters most.
          </p>
          <a href={PHONE_LINK} class="inline-flex items-center gap-2 bg-orange-500 text-white px-7 py-3.5 rounded-full font-bold text-base hover:bg-orange-600 transition-colors duration-300 min-h-[44px]">
            <PhoneIcon class="w-4 h-4" />
            Call {PHONE}
          </a>
        </div>
        <div data-reveal data-reveal-delay="0.15" class="relative">
          {/* Pre-migration: NO width/height attrs on this img — preserved verbatim */}
          <img
            src="/tommy-sydney.webp"
            srcset="/tommy-sydney-mobile.webp 500w, /tommy-sydney.webp 800w"
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            alt="Tommy and Sydney Rankin, owners of Rankin Waste Management"
            class="w-full aspect-[4/3] sm:aspect-[1/1] lg:aspect-[4/5] object-cover object-[50%_30%] rounded-sm"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -left-4 sm:-bottom-6 sm:-left-6 bg-orange-500 text-white px-5 py-3 sm:px-6 sm:py-4 rounded-sm">
            <span class="block text-2xl sm:text-3xl font-bold leading-none">100%</span>
            <span class="text-xs sm:text-sm font-medium opacity-90">Family Owned</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════ WHY CHOOSE US ═══════════════════════ */}
  <section id="why-choose-us" class="px-6 lg:px-[clamp(2rem,5vw,4rem)] py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto">
      <div data-reveal class="text-center mb-12 md:mb-16">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight">Why Choose Rankin Waste Management?</h2>
      </div>
      <div class="max-w-[900px] mx-auto flex flex-col gap-5 md:gap-6">
        {/* 4 cards inline (used 4× only on this page; checkmark SVG repeated verbatim) */}
        <div data-reveal class="bg-dark-card border border-border-subtle rounded-xl p-6 sm:p-8 flex items-start gap-4 sm:gap-5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-7 sm:h-7 text-orange-500 shrink-0 mt-1" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <h3 class="text-lg sm:text-xl font-semibold tracking-tight mb-2">Rural Specialized Service</h3>
            <p class="text-text-muted text-sm sm:text-base leading-relaxed">Built for communities like Hubbard, Axtell, Dawson, Malone, and Mertens where big haulers provide inconsistent service and missed pickups.</p>
          </div>
        </div>

        <div data-reveal data-reveal-delay="0.1" class="bg-dark-card border border-border-subtle rounded-xl p-6 sm:p-8 flex items-start gap-4 sm:gap-5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-7 sm:h-7 text-orange-500 shrink-0 mt-1" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <h3 class="text-lg sm:text-xl font-semibold tracking-tight mb-2">Direct Owner Contact</h3>
            <p class="text-text-muted text-sm sm:text-base leading-relaxed">Call Tommy and Sydney Rankin directly, not a dispatcher in another state or call center queue.</p>
          </div>
        </div>

        <div data-reveal data-reveal-delay="0.2" class="bg-dark-card border border-border-subtle rounded-xl p-6 sm:p-8 flex items-start gap-4 sm:gap-5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-7 sm:h-7 text-orange-500 shrink-0 mt-1" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <h3 class="text-lg sm:text-xl font-semibold tracking-tight mb-2">No Contracts, Flat Pricing</h3>
            <p class="text-text-muted text-sm sm:text-base leading-relaxed">No cancellation fees, fuel surcharges, environmental fees, or automatic annual price hikes.</p>
          </div>
        </div>

        <div data-reveal data-reveal-delay="0.3" class="bg-dark-card border border-border-subtle rounded-xl p-6 sm:p-8 flex items-start gap-4 sm:gap-5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-7 sm:h-7 text-orange-500 shrink-0 mt-1" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <h3 class="text-lg sm:text-xl font-semibold tracking-tight mb-2">Guaranteed Reliability</h3>
            <p class="text-text-muted text-sm sm:text-base leading-relaxed">Consistent pickup schedules with owners personally running routes and solving problems immediately.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════ SERVICES ═══════════════════════ */}
  <section id="services" class="px-6 lg:px-[clamp(2rem,5vw,4rem)] py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto">
      <div data-reveal class="text-center mb-12 md:mb-16">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight">Our Services</h2>
      </div>

      <div data-reveal data-reveal-delay="0.1" class="max-w-[1200px] mx-auto space-y-14 md:space-y-24">
        {/* Row 1: Waste Management — image LEFT (default order) */}
        <div class="grid md:grid-cols-2 gap-6 md:gap-16 items-center">
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/services/waste-management.webp"
              srcset="/images/services/waste-management-mobile.webp 800w, /images/services/waste-management.webp 1400w"
              sizes="(min-width: 768px) 50vw, 100vw"
              alt="Rankin Waste branded curbside trash bin next to service truck"
              width="1400"
              height="933"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[4/3] object-cover"
            />
          </div>
          <div>
            <h3 class="text-xl md:text-2xl font-semibold tracking-tight mb-5">Waste Management Service</h3>
            <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4">
              Our weekly curbside pickup service handles all your household waste without complicated sorting requirements or hidden fees. Simply set out your bags or cans on pickup day and we handle everything else, providing the reliable service that 700+ rural Texas families depend on every week.
            </p>
            <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-5">
              As a family-owned business built specifically for rural communities, we deliver the consistent service and personal accountability that big national haulers can't match in areas like Hubbard and surrounding Hill County towns.
            </p>
            <a href="/waste-management-service-hubbard" class="inline-flex items-center gap-1 text-orange-500 hover:text-orange-300 font-semibold text-sm sm:text-base transition-colors duration-300">
              Learn more about waste management in Hubbard &rarr;
            </a>
          </div>
        </div>

        {/* Row 2: Garbage Collection — image RIGHT (md:order-2/-1 swap) */}
        <div class="grid md:grid-cols-2 gap-6 md:gap-16 items-center">
          <div class="md:order-2 rounded-2xl overflow-hidden">
            <img
              src="/images/services/garbage-collection.webp"
              srcset="/images/services/garbage-collection-mobile.webp 800w, /images/services/garbage-collection.webp 1400w"
              sizes="(min-width: 768px) 50vw, 100vw"
              alt="Rankin Waste garbage truck with RW-branded bins on a rural road"
              width="1400"
              height="1050"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[4/3] object-cover"
            />
          </div>
          <div class="md:order-1">
            <h3 class="text-xl md:text-2xl font-semibold tracking-tight mb-5">Garbage Collection Service</h3>
            <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4">
              We provide a straightforward residential garbage collection service with weekly pickup designed specifically for rural residents. Our service eliminates the frustration of dealing with missed collections and unresponsive customer service, which characterizes most big waste management companies.
            </p>
            <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-5">
              With Tommy and Sydney personally overseeing operations and answering customer calls, any service adjustments or questions get handled immediately by the business owners. This direct communication ensures your garbage collection stays reliable week after week.
            </p>
            <a href="/garbage-collection-service-hubbard" class="inline-flex items-center gap-1 text-orange-500 hover:text-orange-300 font-semibold text-sm sm:text-base transition-colors duration-300">
              Learn more about garbage collection in Hubbard &rarr;
            </a>
          </div>
        </div>

        {/* Row 3: Junk Removal — image LEFT, NO srcset, aspect-[2/1] (different from rows 1/2/4) */}
        <div class="grid md:grid-cols-2 gap-6 md:gap-16 items-center">
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/services/junk-removal.webp"
              alt="Rankin Waste pickup truck pulling black trailer for junk removal"
              width="680"
              height="343"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[2/1] object-cover object-center"
            />
          </div>
          <div>
