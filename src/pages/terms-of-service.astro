---
// src/pages/terms-of-service.astro
// Byte-identical content port of pre-migration src/pages/TermsOfService.jsx.
// Long-form legal text, no schema, no images, no islands.
import Layout from '../layouts/Layout.astro';
import InnerHero from '../components/InnerHero.astro';
---

<Layout
  title="Terms of Service - Rankin Waste Management"
  description="Terms and Conditions for Rankin Waste Management, including SMS messaging consent, communication policies, and service terms."
