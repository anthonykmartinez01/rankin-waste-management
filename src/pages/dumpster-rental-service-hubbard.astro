---
// src/pages/dumpster-rental-service-hubbard.astro
//
// Restructured 2026-05-04 to match /waste-management-service-hubbard
// layout: bgImage InnerHero (using existing /images/services/dumpster-
// rental.webp) + max-w-[1300px] container + 3 alternating image+text
// grid rows + ReviewWidget section + CTA box (with phone + "New Service
// Request" button).
//
// Two head schemas: Service (replaced — was 500-byte slim version, now
// rich version with provider LocalBusiness, OfferCatalog 3 offers,
// AggregateRating 5.0/284, 3 reviews, email included) + BreadcrumbList
// (unchanged).
//
// Service schema applies the rich-result fix: aggregateRating + review
// nested under provider.LocalBusiness (NOT Service root) — same lesson
// as wm-service-hubbard, garbage-collection, and junk-removal pages.
//
// New images under public/images/dumpster-rental/ (6 WebP variants —
// 3 desktop @ 1400w + 3 mobile @ 800w). Sourced from rankin-images/
// Dumpster Rental Service, converted at quality 82 with 4:3 cover crop,
// ~96% file size reduction vs source PNGs.
import Layout from '../layouts/Layout.astro';
import InnerHero from '../components/InnerHero.astro';
import CallCTA from '../components/CallCTA.astro';
import ReviewWidget from '../components/ReviewWidget.tsx';
import { PHONE, PHONE_LINK } from '../data/business';
---

<Layout
  title="Dump Trailer Rental Service Hubbard TX | Rankin Waste Management"
  description="Dump trailer rental in Hubbard, TX — 14-yard dump trailers. Same-day delivery, 3-day standard rentals, flat-rate pricing. Call (254) 205-6125."
  image="/images/services/dumpster-rental.webp"
  imageAlt="Black dump trailer loaded with debris parked in a Hubbard field at sunset"
>
  <Fragment slot="head">
    {/* Service schema — provided by user 2026-05-04, applied verbatim
        EXCEPT for two known fixes carried forward from prior pages:
          1. aggregateRating + review nested under provider.LocalBusiness
             (NOT Service root) — Google's review-snippet docs require
             an eligible parent type (LocalBusiness, not Service)
          2. email field added to provider.LocalBusiness for NAP parity
             with the other 3 Hubbard pages
        All other content preserved exactly as pasted. */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://rankinwaste.com/dumpster-rental-service-hubbard/#service",
      "name": "Dump Trailer Rental Service in Hubbard, TX",
      "description": "Local dump trailer rentals in Hubbard for cleanouts, renovations, commercial waste, and yard projects. 14-yard dump trailers, flexible rental periods starting at 3 days, and same-day delivery available — family-owned, flat-rate pricing, no contracts.",
      "serviceType": "Dump Trailer Rental",
      "category": "Dump Trailer Rental Service",
      "url": "https://rankinwaste.com/dumpster-rental-service-hubbard/",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://rankinwaste.com/#business",
        "name": "Rankin Waste Management",
        "telephone": "+1-254-205-6125",
        "email": "rankinwaste@gmail.com",
        "url": "https://rankinwaste.com/",
        "image": "https://rankinwaste.com/rw-logo.webp",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "175 PR335",
          "addressLocality": "Hubbard",
          "addressRegion": "TX",
          "postalCode": "76648",
          "addressCountry": "US"
        },
        "priceRange": "$$",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "08:00",
            "closes": "18:00"
          }
        ],
        "sameAs": [
          "https://www.facebook.com/p/Rankin-waste-management-100057417520840/"
        ],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
          "reviewCount": "284",
          "bestRating": "5",
          "worstRating": "1"
        },
        "review": [
          {
            "@type": "Review",
            "author": { "@type": "Person", "name": "Kayla Jones" },
            "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
            "reviewBody": "If you're looking for a waste service that truly goes above and beyond, Rankin Waste Management is it. Tommy and Sydney are reliable, affordable, and somehow still the kind of people who show up for everything like ballgames, school events, and anything that supports our kids and community. They run their business the way small-town businesses should be run, treating people like family, not just customers. 10/10 recommend."
          },
          {
            "@type": "Review",
            "author": { "@type": "Person", "name": "Megan Lee" },
            "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
            "reviewBody": "We switched to Rankin after spending hundreds on mediocre service. Rankin has exceeded our expectations! They are communicative, passionate about their business and keeping it, and local! I love that they now provide trash cans! Give them a text or call, I promise you'll get an answer for every question!"
          },
          {
            "@type": "Review",
            "author": { "@type": "Person", "name": "Buffy Nehring" },
            "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
            "reviewBody": "They are a family owned business. They are always on time for pickup. They provide amazing customer service. They have quick response should you have questions. They treat you like family not just another account. They have great pricing. I highly recommend them."
          }
        ]
      },
      "areaServed": {
        "@type": "City",
        "name": "Hubbard",
        "containedInPlace": {
          "@type": "State",
          "name": "Texas"
        }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Dump Trailer Rental Services in Hubbard",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Residential Dump Trailer Rental in Hubbard",
              "description": "14-yard dump trailers with lower walls that are easier to load and tires that won't damage your driveway. Built for garage cleanouts, attic and shed clearings, home renovations, yard projects, move-outs, and full estate cleanouts. Standard rentals start at 3 days, with additional days available upon request, plus same-day or next-day delivery across in-town, county-line, and rural addresses in Hubbard.",
              "areaServed": { "@type": "City", "name": "Hubbard" },
              "provider": { "@id": "https://rankinwaste.com/#business" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Commercial Dump Trailer Rental in Hubbard",
              "description": "Dump trailer service for local businesses, retail stores, restaurants, churches, and small offices in Hubbard. Built for one-time cleanouts, remodel projects, end-of-lease haul-outs, renovation debris, fixture changeovers, kitchen tear-outs, and storeroom decluttering. Flat-rate pricing with delivery and pickup coordinated around your business hours — same-day delivery available for most Hubbard neighborhoods.",
              "areaServed": { "@type": "City", "name": "Hubbard" },
              "provider": { "@id": "https://rankinwaste.com/#business" }
            }
          }
        ]
      }
    })} />

    {/* Breadcrumb Schema (unchanged from migration) */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rankinwaste.com/" },
        { "@type": "ListItem", "position": 2, "name": "Dump Trailer Rental Service in Hubbard", "item": "https://rankinwaste.com/dumpster-rental-service-hubbard" }
      ]
    })} />
  </Fragment>

  <InnerHero
    title="Dump Trailer Rental Service in Hubbard"
    bgImage="/images/services/dumpster-rental.webp"
    bgImageMobile="/images/services/dumpster-rental-mobile.webp"
    bgImageAlt="Black dump trailer loaded with debris parked in a Hubbard field at sunset"
  />

  <section class="px-5 sm:px-6 lg:px-[clamp(2rem,5vw,4rem)] py-12 md:py-20 lg:py-28">
    <div class="max-w-[1300px] mx-auto">

      {/* Intro */}
      <div data-reveal class="mb-12 md:mb-16 max-w-[900px] mx-auto text-center">
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4 md:mb-6">
          In Hubbard, homeowners and businesses need reliable waste removal solutions for projects big and small. Rankin Waste Management's dump trailer rental service handles residential cleanouts, light commercial work, renovation debris, yard projects, and full-property haul-outs across Hubbard and the surrounding rural communities.
        </p>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed">
          Instead of a traditional steel roll-off, we use a 14-yard dump trailer (roughly four pickup-truck loads of capacity). It drops in your driveway just like a dumpster, but it loads at ground level, won't crack your concrete, and fits into rural driveways a roll-off truck couldn't reach. We deliver to your location, give you 3 days to load it standard (additional days available upon request), and haul it away on your schedule. No contracts, flat-rate pricing, and a phone you can call at any time.
        </p>
      </div>

      {/* Residential — image left */}
      <div data-reveal data-reveal-delay="0.1" class="mb-16 md:mb-24 grid md:grid-cols-2 gap-6 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden">
          <img
            src="/images/dumpster-rental/residential.webp"
            srcset="/images/dumpster-rental/residential-mobile.webp 800w, /images/dumpster-rental/residential.webp 1400w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="White pickup truck towing a black dump trailer loaded with yard debris in front of a Hubbard home"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Residential Dump Trailer Rental in Hubbard</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4 md:mb-6">
            Homeowners tackling garage cleanouts, attic and shed clearings, home renovations, yard projects, and move-outs need a waste solution that's easier to load than a steel roll-off and big enough to actually finish the job. Our 14-yard dump trailers give you the capacity you need with lower walls you don't have to heave debris over and tires that won't damage your driveway.
          </p>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4 md:mb-6">
            We deliver across every residential area in Hubbard, including in-town homes, county-line properties, and rural addresses well outside the city limits. Standard rentals start at 3 days, with additional days available upon request, so you can load at your own pace. Most Hubbard customers can get same-day or next-day delivery — just give us a call in the morning. From single-room remodels and yard overhauls to full estate cleanouts, this is the right service for almost any home project.
          </p>
          <a href="/trash-trailer-rentals" class="inline-flex items-center gap-1 text-orange-500 hover:text-orange-300 font-semibold text-sm sm:text-base transition-colors duration-300">
            Learn more about our trash trailer rentals &rarr;
          </a>
        </div>
      </div>

      {/* Commercial — image RIGHT (md:order-2 / md:order-1 swap) */}
      <div data-reveal data-reveal-delay="0.1" class="mb-16 md:mb-24 grid md:grid-cols-2 gap-6 md:gap-16 items-center">
        <div class="md:order-2 rounded-2xl overflow-hidden">
          <img
            src="/images/dumpster-rental/commercial.webp"
            srcset="/images/dumpster-rental/commercial-mobile.webp 800w, /images/dumpster-rental/commercial.webp 1400w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="White pickup truck towing a loaded black dump trailer outside a Hubbard commercial warehouse"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div class="md:order-1">
          <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Commercial Dump Trailer Rental in Hubbard</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4 md:mb-6">
            Local businesses, retail stores, restaurants, churches, and small offices in Hubbard need a waste solution they can count on for one-time cleanouts, remodel projects, and end-of-lease haul-outs. Our dump trailer service works well for renovation debris, fixture changeovers, kitchen tear-outs, storeroom decluttering, and general business cleanups.
          </p>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed">
            We coordinate delivery and pickup around your business hours so we're not blocking customer parking or in the way during operations. Our flat-rate pricing makes it easy to plan projects accurately, and our service covers all Hubbard commercial areas with same-day delivery available for most neighborhoods.
          </p>
        </div>
      </div>

      {/* Dumpster Sizes — full-width informational block (no image pair) */}
      <div data-reveal data-reveal-delay="0.1" class="max-w-[900px] mx-auto">
        <h3 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Dump Trailer Sizes We Offer</h3>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-6 md:mb-8">
          We keep things simple: one trailer, one capacity, the size that handles roughly 95% of residential cleanup jobs. Instead of offering four different roll-off sizes that mostly confuse people, we built our business around the size homeowners actually need — a 14-yard dump trailer.
        </p>

        <div class="rounded-2xl overflow-hidden mb-6 md:mb-8">
          <img
            src="/images/dumpster-rental/sizes.webp"
            srcset="/images/dumpster-rental/sizes-mobile.webp 800w, /images/dumpster-rental/sizes.webp 1400w"
            sizes="(min-width: 768px) 900px, 100vw"
            alt="14-yard dump trailer loaded with debris in a Hubbard residential driveway"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>

        <h4 class="text-xl md:text-2xl font-bold mb-3 md:mb-4">Our 14-Yard Dump Trailer</h4>
        <ul class="text-text-muted text-base sm:text-lg leading-relaxed mb-6 md:mb-8 space-y-2 list-disc pl-6 marker:text-orange-500">
          <li><span class="font-semibold text-white">Capacity:</span> ~14 cubic yards</li>
          <li><span class="font-semibold text-white">Type:</span> Dump trailer — loads at ground level, no climbing required</li>
          <li><span class="font-semibold text-white">Walls:</span> High sides — load up to the top rail</li>
          <li><span class="font-semibold text-white">Pickup-truck equivalent:</span> About 4 full pickup-truck loads of debris</li>
          <li><span class="font-semibold text-white">Rental period:</span> Starts at 3 days standard, with additional days available upon request</li>
        </ul>

        <h4 class="text-xl md:text-2xl font-bold mb-3 md:mb-4">Why one size works for almost every job in Hubbard</h4>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-4 md:mb-6">
          A 14-yard dump trailer is big enough for a full garage cleanout, a kitchen remodel, a yard overhaul, a small to mid-size roofing tear-off, or a move-out clean — but small enough to fit in a normal driveway without blocking your car. Going smaller usually means you run out of room and have to schedule a second haul. Going bigger usually means you're paying for empty space you won't fill.
        </p>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed">
          If you're working on something extremely heavy like concrete, brick, dirt, or a full demolition job, call us first so we can confirm the load is safe to haul under <a href="https://www.tceq.texas.gov/permitting/waste_permits/msw_permits" target="_blank" rel="noopener" class="text-orange-500 hover:text-orange-300 underline underline-offset-2 transition-colors duration-300">Texas waste regulations</a> and adjust the quote accordingly. For everything else, our one trailer is built to be the right size right out of the gate.
        </p>
      </div>

    </div>
  </section>

  <section id="reviews" class="bg-dark-elevated">
    <ReviewWidget client:idle />
  </section>

  <section class="px-5 sm:px-6 lg:px-[clamp(2rem,5vw,4rem)] py-12 md:py-20 lg:py-28">
    <div class="max-w-[1300px] mx-auto">
      {/* CTA */}
      <div data-reveal data-reveal-delay="0.1" class="bg-dark-elevated border border-border-subtle rounded-2xl p-6 sm:p-8 md:p-12 text-center">
        <h2 class="text-xl sm:text-2xl md:text-3xl font-bold mb-3 md:mb-4">Reserve Your Hubbard Dump Trailer Today</h2>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-6 md:mb-8">
          Call Rankin Waste Management at <a href={PHONE_LINK} class="text-orange-500 hover:text-orange-400 font-semibold">{PHONE}</a> for an upfront quote. Family-owned, no contracts, flat-rate pricing — and trusted by 700+ neighbors with 250+ five-star reviews.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <CallCTA />
          <button id="dumpster-rental-modal-trigger" type="button" class="border border-white/30 text-white px-7 py-3.5 rounded-full font-semibold text-base hover:bg-white/20 transition-colors duration-300 min-h-[44px]">
            New Service Request
          </button>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var b = document.getElementById('dumpster-rental-modal-trigger');
      if (b) b.addEventListener('click', function () {
        document.dispatchEvent(new CustomEvent('open-service-modal'));
      });
    })();
  </script>
</Layout>
