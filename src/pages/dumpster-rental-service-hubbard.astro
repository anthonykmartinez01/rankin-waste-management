---
// src/pages/dumpster-rental-service-hubbard.astro
//
// Restructured 2026-05-04 to match /waste-management-service-hubbard
// layout: bgImage InnerHero (using existing /images/services/dumpster-
// rental.webp) + max-w-[1300px] container + 3 alternating image+text
// grid rows + ReviewWidget section + CTA box (with phone + "New Service
// Request" button).
//
// Two head schemas: Service (replaced — was 500-byte slim version, now
// rich version with provider LocalBusiness, OfferCatalog 3 offers,
// AggregateRating 5.0/284, 3 reviews, email included) + BreadcrumbList
// (unchanged).
//
// Service schema applies the rich-result fix: aggregateRating + review
// nested under provider.LocalBusiness (NOT Service root) — same lesson
// as wm-service-hubbard, garbage-collection, and junk-removal pages.
//
// New images under public/images/dumpster-rental/ (6 WebP variants —
// 3 desktop @ 1400w + 3 mobile @ 800w). Sourced from rankin-images/
// Dumpster Rental Service, converted at quality 82 with 4:3 cover crop,
// ~96% file size reduction vs source PNGs.
import Layout from '../layouts/Layout.astro';
import InnerHero from '../components/InnerHero.astro';
import CallCTA from '../components/CallCTA.astro';
import ReviewWidget from '../components/ReviewWidget.tsx';
import { PHONE, PHONE_LINK } from '../data/business';
---

<Layout
  title="Dumpster Rental Service Hubbard TX | Rankin Waste Management"
  description="Professional dumpster rental service in Hubbard, TX. Residential cleanouts, commercial waste, and construction roll-off containers. Local delivery and pickup by Rankin Waste Management."
  image="/images/services/dumpster-rental.webp"
  imageAlt="Black metal roll-off dumpster at a construction site"
>
  <Fragment slot="head">
    {/* Service schema — provided by user 2026-05-04, applied verbatim
        per explicit instruction. NOTE: aggregateRating + review are
        on the Service root (not under provider.LocalBusiness), which
        is NOT Google's preferred shape — Rich Results Test will likely
        flag this with "Invalid object type for field <parent_node>"
        on the review field. Apply the review-under-provider fix only
        if the user requests it. */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://rankinwaste.com/dumpster-rental-service-hubbard/#service",
      "name": "Dumpster Rental Service in Hubbard, TX",
      "description": "Local dumpster rentals in Hubbard for cleanouts, renovations, commercial waste, and construction debris. Right-sized containers, flexible rental periods, and same-day delivery available — family-owned, flat-rate pricing, no contracts.",
      "serviceType": "Dumpster Rental",
      "category": "Dumpster Rental Service",
      "url": "https://rankinwaste.com/dumpster-rental-service-hubbard/",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://rankinwaste.com/#business",
        "name": "Rankin Waste Management",
        "telephone": "+1-254-205-6125",
        "url": "https://rankinwaste.com/",
        "image": "https://rankinwaste.com/rw-logo.webp",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "175 PR335",
          "addressLocality": "Hubbard",
          "addressRegion": "TX",
          "postalCode": "76648",
          "addressCountry": "US"
        },
        "priceRange": "$$",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "08:00",
            "closes": "18:00"
          }
        ],
        "sameAs": [
          "https://www.facebook.com/p/Rankin-waste-management-100057417520840/"
        ]
      },
      "areaServed": {
        "@type": "City",
        "name": "Hubbard",
        "containedInPlace": {
          "@type": "State",
          "name": "Texas"
        }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Dumpster Rental Services in Hubbard",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Residential Dumpster Rental in Hubbard",
              "description": "Garage cleanout, basement clearing, big yard project? We drop a right-sized container in your driveway, you fill it on your own time, and we haul it off when you're done. Same-day delivery available for most Hubbard neighborhoods.",
              "areaServed": { "@type": "City", "name": "Hubbard" },
              "provider": { "@id": "https://rankinwaste.com/#business" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Commercial Dumpster Rental in Hubbard",
              "description": "Retail stores, restaurants, offices — local businesses need waste service that just works. Ongoing contracts, flexible pickup schedules, and coverage across downtown Hubbard and the surrounding commercial zones.",
              "areaServed": { "@type": "City", "name": "Hubbard" },
              "provider": { "@id": "https://rankinwaste.com/#business" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Roll-off Dumpster Service in Hubbard",
              "description": "Built for contractors, builders, and demo crews. Heavy-duty roll-off containers for construction debris, roofing tear-offs, and demolition material — easy loading access, permits handled when required. For other large-haul jobs, ask about trash trailer rentals.",
              "areaServed": { "@type": "City", "name": "Hubbard" },
              "provider": { "@id": "https://rankinwaste.com/#business" }
            }
          }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "284",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Kayla Jones" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "If you're looking for a waste service that truly goes above and beyond, Rankin Waste Management is it. Tommy and Sydney are reliable, affordable, and somehow still the kind of people who show up for everything like ballgames, school events, and anything that supports our kids and community. They run their business the way small-town businesses should be run, treating people like family, not just customers. 10/10 recommend."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Megan Lee" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "We switched to Rankin after spending hundreds on mediocre service. Rankin has exceeded our expectations! They are communicative, passionate about their business and keeping it, and local! I love that they now provide trash cans! Give them a text or call, I promise you'll get an answer for every question!"
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Buffy Nehring" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "They are a family owned business. They are always on time for pickup. They provide amazing customer service. They have quick response should you have questions. They treat you like family not just another account. They have great pricing. I highly recommend them."
        }
      ]
    })} />

    {/* Breadcrumb Schema (unchanged from migration) */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rankinwaste.com/" },
        { "@type": "ListItem", "position": 2, "name": "Dumpster Rental Service in Hubbard", "item": "https://rankinwaste.com/dumpster-rental-service-hubbard" }
      ]
    })} />
  </Fragment>

  <InnerHero
    title="Dumpster Rental Service in Hubbard"
    bgImage="/images/services/dumpster-rental.webp"
    bgImageMobile="/images/services/dumpster-rental-mobile.webp"
    bgImageAlt="Black metal roll-off dumpster at a construction site"
  />

  <section class="px-5 sm:px-6 lg:px-[clamp(2rem,5vw,4rem)] py-12 md:py-20 lg:py-28">
    <div class="max-w-[1300px] mx-auto">

      {/* Intro */}
      <div data-reveal class="mb-12 md:mb-16 text-center">
        <p class="text-text-muted text-base sm:text-lg leading-relaxed">
          In Hubbard, homeowners and businesses need reliable waste removal solutions for projects big and small. Our dumpster rental service in Hubbard handles residential cleanouts, commercial projects, and construction debris removal. Choose the right container size and schedule delivery to your Hubbard location. We provide local pickup and drop-off with flexible rental periods to match your project timeline.
        </p>
      </div>

      {/* Residential — image left */}
      <div data-reveal data-reveal-delay="0.1" class="mb-16 md:mb-24 grid md:grid-cols-2 gap-6 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden">
          <img
            src="/images/dumpster-rental/residential.webp"
            srcset="/images/dumpster-rental/residential-mobile.webp 800w, /images/dumpster-rental/residential.webp 1400w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="Black residential dumpster on a homeowner's driveway with a Hubbard home in the background"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Residential Dumpster Rental in Hubbard</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed">
            Homeowners tackling garage cleanouts, basement clearing, home renovations, and yard cleanup projects need the right waste solution. We deliver right-sized containers for household waste with convenient driveway placement and scheduled pickup. Our service covers all Hubbard residential areas with same-day delivery available for most neighborhoods.
          </p>
        </div>
      </div>

      {/* Commercial — image RIGHT (md:order-2 / md:order-1 swap) */}
      <div data-reveal data-reveal-delay="0.1" class="mb-16 md:mb-24 grid md:grid-cols-2 gap-6 md:gap-16 items-center">
        <div class="md:order-2 rounded-2xl overflow-hidden">
          <img
            src="/images/dumpster-rental/commercial.webp"
            srcset="/images/dumpster-rental/commercial-mobile.webp 800w, /images/dumpster-rental/commercial.webp 1400w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="Black commercial dumpster outside a Hubbard business with metal warehouse siding"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div class="md:order-1">
          <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Commercial Dumpster Rental in Hubbard</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed">
            Local businesses, retail stores, restaurants, and office buildings need regular waste management they can count on. We provide ongoing service contracts with flexible pickup schedules. Our commercial service covers Hubbard's downtown business district and surrounding commercial zones.
          </p>
        </div>
      </div>

      {/* Roll-off — image left */}
      <div data-reveal data-reveal-delay="0.1" class="mb-16 md:mb-24 grid md:grid-cols-2 gap-6 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden">
          <img
            src="/images/dumpster-rental/rolloff.webp"
            srcset="/images/dumpster-rental/rolloff-mobile.webp 800w, /images/dumpster-rental/rolloff.webp 1400w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="Roll-off truck delivering a black roll-off dumpster on a Hubbard job site"
            width="1400"
            height="1050"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Roll-off Dumpster Service in Hubbard</h2>
          <p class="text-text-muted text-base sm:text-lg leading-relaxed">
            Construction crews, contractors, and property developers managing building debris and large-scale cleanouts require heavy-duty solutions. We supply sturdy containers for construction waste, roofing materials, and demolition debris with easy loading access. Our roll-off service covers construction sites throughout the Hubbard area with permits handled when required. For other large-haul needs, see our trash trailer rentals.
          </p>
        </div>
      </div>

    </div>
  </section>

  <section id="reviews" class="bg-dark-elevated">
    <ReviewWidget client:idle />
  </section>

  <section class="px-5 sm:px-6 lg:px-[clamp(2rem,5vw,4rem)] py-12 md:py-20 lg:py-28">
    <div class="max-w-[1300px] mx-auto">
      {/* CTA */}
      <div data-reveal data-reveal-delay="0.1" class="bg-dark-elevated border border-border-subtle rounded-2xl p-6 sm:p-8 md:p-12 text-center">
        <h2 class="text-xl sm:text-2xl md:text-3xl font-bold mb-3 md:mb-4">Reserve Your Hubbard Dumpster Today</h2>
        <p class="text-text-muted text-base sm:text-lg leading-relaxed mb-6 md:mb-8">
          Call Rankin Waste Management at <a href={PHONE_LINK} class="text-orange-500 hover:text-orange-400 font-semibold">{PHONE}</a> for an upfront quote. Family-owned, no contracts, flat-rate pricing — and trusted by 700+ neighbors with 250+ five-star reviews.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <CallCTA />
          <button id="dumpster-rental-modal-trigger" type="button" class="border border-white/30 text-white px-7 py-3.5 rounded-full font-semibold text-base hover:bg-white/20 transition-colors duration-300 min-h-[44px]">
            New Service Request
          </button>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var b = document.getElementById('dumpster-rental-modal-trigger');
      if (b) b.addEventListener('click', function () {
        document.dispatchEvent(new CustomEvent('open-service-modal'));
      });
    })();
  </script>
</Layout>
